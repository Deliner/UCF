{
  "$comment": "Generated deterministically from UCF ratchet profile 1.0.0 models; do not edit by hand. Content identities, canonical order, resolved references, exact source projections, predecessor lineage, and recomputed summaries remain runtime semantics.",
  "$defs": {
    "AssessmentId": {
      "pattern": "^assessment\\.[0-9a-f]{64}$",
      "type": "string"
    },
    "BaselineId": {
      "pattern": "^baseline\\.[0-9a-f]{64}$",
      "type": "string"
    },
    "BehaviorSubjectId": {
      "pattern": "^subject\\.[0-9a-f]{64}$",
      "type": "string"
    },
    "BehaviorSubjectRef": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "behavior_subject_ref",
          "title": "Kind",
          "type": "string"
        },
        "target_id": {
          "$ref": "#/$defs/BehaviorSubjectId"
        }
      },
      "required": [
        "kind",
        "target_id"
      ],
      "title": "BehaviorSubjectRef",
      "type": "object"
    },
    "Digest": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "sha-256",
          "title": "Algorithm",
          "type": "string"
        },
        "kind": {
          "const": "digest",
          "title": "Kind",
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/DigestValue"
        }
      },
      "required": [
        "kind",
        "algorithm",
        "value"
      ],
      "title": "Digest",
      "type": "object"
    },
    "DigestValue": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "EvaluationId": {
      "pattern": "^evaluation\\.[0-9a-f]{64}$",
      "type": "string"
    },
    "EvaluationOutcome": {
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ],
      "title": "EvaluationOutcome",
      "type": "string"
    },
    "Identifier": {
      "maxLength": 255,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "type": "string"
    },
    "NormalizedVersion": {
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$",
      "type": "string"
    },
    "PolicyId": {
      "pattern": "^policy\\.[0-9a-f]{64}$",
      "type": "string"
    },
    "RatchetAssessmentRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_digest": {
          "$ref": "#/$defs/Digest"
        },
        "kind": {
          "const": "ratchet_assessment_ref",
          "title": "Kind",
          "type": "string"
        },
        "schema_uri": {
          "const": "urn:ucf:ratchet:assessment:1.0.0",
          "title": "Schema Uri",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "target_id": {
          "$ref": "#/$defs/AssessmentId"
        }
      },
      "required": [
        "kind",
        "schema_uri",
        "schema_version",
        "target_id",
        "canonical_digest"
      ],
      "title": "RatchetAssessmentRef",
      "type": "object"
    },
    "RatchetBaselineRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_digest": {
          "$ref": "#/$defs/Digest"
        },
        "generation": {
          "$ref": "#/$defs/SafeInteger"
        },
        "kind": {
          "const": "ratchet_baseline_ref",
          "title": "Kind",
          "type": "string"
        },
        "schema_uri": {
          "const": "urn:ucf:ratchet:baseline:1.0.0",
          "title": "Schema Uri",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "target_id": {
          "$ref": "#/$defs/BaselineId"
        }
      },
      "required": [
        "kind",
        "schema_uri",
        "schema_version",
        "target_id",
        "canonical_digest",
        "generation"
      ],
      "title": "RatchetBaselineRef",
      "type": "object"
    },
    "RatchetPolicyRef": {
      "additionalProperties": false,
      "properties": {
        "canonical_digest": {
          "$ref": "#/$defs/Digest"
        },
        "kind": {
          "const": "ratchet_policy_ref",
          "title": "Kind",
          "type": "string"
        },
        "schema_uri": {
          "const": "urn:ucf:ratchet:policy:1.0.0",
          "title": "Schema Uri",
          "type": "string"
        },
        "schema_version": {
          "const": "1.0.0",
          "title": "Schema Version",
          "type": "string"
        },
        "target_id": {
          "$ref": "#/$defs/PolicyId"
        }
      },
      "required": [
        "kind",
        "schema_uri",
        "schema_version",
        "target_id",
        "canonical_digest"
      ],
      "title": "RatchetPolicyRef",
      "type": "object"
    },
    "RatchetRuleRef": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "ratchet_rule_ref",
          "title": "Kind",
          "type": "string"
        },
        "target_id": {
          "$ref": "#/$defs/Identifier"
        },
        "version": {
          "$ref": "#/$defs/NormalizedVersion"
        }
      },
      "required": [
        "kind",
        "target_id",
        "version"
      ],
      "title": "RatchetRuleRef",
      "type": "object"
    },
    "SafeInteger": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "SubjectChange": {
      "additionalProperties": false,
      "properties": {
        "change": {
          "$ref": "#/$defs/SubjectChangeKind"
        },
        "kind": {
          "const": "ratchet_subject_change",
          "title": "Kind",
          "type": "string"
        },
        "subject": {
          "$ref": "#/$defs/BehaviorSubjectRef"
        }
      },
      "required": [
        "kind",
        "subject",
        "change"
      ],
      "title": "SubjectChange",
      "type": "object"
    },
    "SubjectChangeKind": {
      "enum": [
        "unchanged",
        "semantic_changed",
        "observed_changed",
        "semantic_and_observed_changed",
        "new_subject",
        "removed_subject",
        "unknown_subject"
      ],
      "title": "SubjectChangeKind",
      "type": "string"
    },
    "ViolationClassification": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "$ref": "#/$defs/ViolationClassificationKind"
        },
        "key": {
          "$ref": "#/$defs/ViolationKey"
        },
        "kind": {
          "const": "ratchet_violation_classification",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "classification",
        "key"
      ],
      "title": "ViolationClassification",
      "type": "object"
    },
    "ViolationClassificationKind": {
      "enum": [
        "unchanged_legacy",
        "new_regression",
        "touched_legacy",
        "reintroduced",
        "resolved",
        "unknown"
      ],
      "title": "ViolationClassificationKind",
      "type": "string"
    },
    "ViolationKey": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "violation_key",
          "title": "Kind",
          "type": "string"
        },
        "rule": {
          "$ref": "#/$defs/RatchetRuleRef"
        },
        "slot": {
          "$ref": "#/$defs/Identifier"
        },
        "subject": {
          "$ref": "#/$defs/BehaviorSubjectRef"
        }
      },
      "required": [
        "kind",
        "rule",
        "subject",
        "slot"
      ],
      "title": "ViolationKey",
      "type": "object"
    },
    "WeakeningDelta": {
      "additionalProperties": false,
      "properties": {
        "added_allowances": {
          "items": {
            "$ref": "#/$defs/ViolationKey"
          },
          "maxItems": 65536,
          "title": "Added Allowances",
          "type": "array"
        },
        "kind": {
          "const": "weakening_delta",
          "title": "Kind",
          "type": "string"
        },
        "removed_allowances": {
          "items": {
            "$ref": "#/$defs/ViolationKey"
          },
          "maxItems": 65536,
          "title": "Removed Allowances",
          "type": "array"
        },
        "removed_protections": {
          "items": {
            "$ref": "#/$defs/ViolationKey"
          },
          "maxItems": 65536,
          "title": "Removed Protections",
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/WeakeningDeltaStatus"
        }
      },
      "required": [
        "kind",
        "status",
        "added_allowances",
        "removed_allowances",
        "removed_protections"
      ],
      "title": "WeakeningDelta",
      "type": "object"
    },
    "WeakeningDeltaStatus": {
      "enum": [
        "none",
        "tightening",
        "review_required"
      ],
      "title": "WeakeningDeltaStatus",
      "type": "string"
    }
  },
  "$id": "urn:ucf:ratchet:evaluation-report:1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assessment": {
      "$ref": "#/$defs/RatchetAssessmentRef"
    },
    "baseline": {
      "$ref": "#/$defs/RatchetBaselineRef"
    },
    "classifications": {
      "items": {
        "$ref": "#/$defs/ViolationClassification"
      },
      "maxItems": 131072,
      "title": "Classifications",
      "type": "array"
    },
    "id": {
      "$ref": "#/$defs/EvaluationId"
    },
    "kind": {
      "const": "ratchet_evaluation_report",
      "title": "Kind",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/$defs/EvaluationOutcome"
    },
    "policy": {
      "$ref": "#/$defs/RatchetPolicyRef"
    },
    "procedure_uri": {
      "const": "urn:ucf:ratchet:evaluate:1.0.0",
      "title": "Procedure Uri",
      "type": "string"
    },
    "ratchet_version": {
      "const": "1.0.0",
      "title": "Ratchet Version",
      "type": "string"
    },
    "schema_uri": {
      "const": "urn:ucf:ratchet:evaluation-report:1.0.0",
      "title": "Schema Uri",
      "type": "string"
    },
    "subject_changes": {
      "items": {
        "$ref": "#/$defs/SubjectChange"
      },
      "maxItems": 512,
      "title": "Subject Changes",
      "type": "array"
    },
    "weakening_delta": {
      "$ref": "#/$defs/WeakeningDelta"
    }
  },
  "required": [
    "kind",
    "ratchet_version",
    "schema_uri",
    "id",
    "policy",
    "baseline",
    "assessment",
    "procedure_uri",
    "subject_changes",
    "classifications",
    "outcome",
    "weakening_delta"
  ],
  "title": "UCF ratchet evaluation report profile 1.0.0",
  "type": "object",
  "x-ucf-document-kind": "ratchet_evaluation_report",
  "x-ucf-normative-algorithms": [
    "urn:ucf:ratchet:fingerprint:observed-subject:1.0.0",
    "urn:ucf:ratchet:evaluate:1.0.0",
    "urn:ucf:ratchet:fingerprint:behavior-subject:1.0.0"
  ],
  "x-ucf-ratchet-version": "1.0.0",
  "x-ucf-runtime-semantic-checks": [
    "strict UTF-8 and duplicate-member JSON decoding",
    "maximum JSON nesting depth 128",
    "content-derived policy, subject, violation, assessment, baseline, and report identities",
    "exact policy, onboarding bundle, assessment, baseline, predecessor, and report references",
    "canonical unique rule, subject, violation, classification, allowance, and protection order",
    "resolved non-provenance behavior subject projection",
    "resolved rename-neutral observed evidence projection",
    "complete subject and rule coverage before baseline creation or advance",
    "recomputed unchanged, touched, regression, resolution, and unknown classifications",
    "immutable predecessor-bound tightening with retained protected resolutions",
    "explicit review delta without implicit baseline weakening",
    "maximum 256 policy rules",
    "maximum 256 current subjects",
    "maximum 65536 violation identities"
  ]
}
