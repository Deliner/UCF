  "title": "UCF ratchet assessment profile 1.0.0",
  "type": "object",
  "x-ucf-document-kind": "ratchet_assessment",
  "x-ucf-normative-algorithms": [
    "urn:ucf:ratchet:fingerprint:observed-subject:1.0.0",
    "urn:ucf:ratchet:evaluate:1.0.0",
    "urn:ucf:ratchet:fingerprint:behavior-subject:1.0.0"
  ],
  "x-ucf-ratchet-version": "1.0.0",
  "x-ucf-runtime-semantic-checks": [
    "strict UTF-8 and duplicate-member JSON decoding",
    "maximum JSON nesting depth 128",
    "content-derived policy, subject, violation, assessment, baseline, and report identities",
    "exact policy, onboarding bundle, assessment, baseline, predecessor, and report references",
    "canonical unique rule, subject, violation, classification, allowance, and protection order",
    "resolved non-provenance behavior subject projection",
    "resolved rename-neutral observed evidence projection",
    "complete subject and rule coverage before baseline creation or advance",
    "recomputed unchanged, touched, regression, resolution, and unknown classifications",
    "immutable predecessor-bound tightening with retained protected resolutions",
    "explicit review delta without implicit baseline weakening",
    "maximum 256 policy rules",
    "maximum 256 current subjects",
    "maximum 65536 violation identities"
  ]
