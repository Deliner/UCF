        "name",
        "version"
      ],
      "title": "Producer",
      "type": "object"
    },
    "QualifiedName": {
      "maxLength": 255,
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)+$",
